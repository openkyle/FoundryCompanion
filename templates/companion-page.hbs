<section class="foundry-companion-page">
  <header class="companion-header">
    <div>
      <p class="eyebrow">{{worldTitle}}</p>
      <h1>{{title}}</h1>
      <p class="meta">{{count}} publishable records. Updated {{updatedAt}}.</p>
      {{#if summary}}
        <p class="meta">
          Quests {{summary.quests}} · Story {{summary.storyChapters}} · Journal {{summary.journalEntries}} · Contacts {{summary.contacts}} · Items {{summary.items}} · Characters {{summary.characterSheets}} · Ships {{summary.tradeHubShips}}
        </p>
      {{/if}}
      <p class="meta">Mode: {{publishMode}} · Images: {{imageMode}}</p>
    </div>
    <div class="companion-actions">
      <button type="button" data-action="refresh" title="Refresh">
        <i class="fas fa-sync"></i>
      </button>
      <button type="button" data-action="export" title="Export JSON">
        <i class="fas fa-file-export"></i>
      </button>
    </div>
  </header>

  <nav class="companion-nav">
    {{#each navigation}}
      <a href="#fc-{{id}}">{{label}}</a>
    {{/each}}
  </nav>

  <main class="companion-sections">
    {{#if questLog.enabled}}
      <section id="fc-questLog" class="preview-section">
        <h2>Quest Log</h2>
        {{#if sections.length}}
          {{#each sections}}
            <section class="quest-section">
              <h3>{{status}}</h3>
              <div class="quest-list">
                {{#each items}}
                  <article class="quest-card">
                    <header>
                      {{#if imageUrl}}<img class="quest-image" src="{{imageUrl}}" alt="">{{/if}}
                      <h4>{{title}}</h4>
                      <p class="quest-details">
                        {{#if mainQuest}}<span>Main Quest</span>{{/if}}
                        {{#if giver.name}}<span>Giver: {{giver.name}}</span>{{/if}}
                        {{#if location}}<span>Location: {{location}}</span>{{/if}}
                        {{#if progress.total}}<span>{{progress.completed}}/{{progress.total}} objectives</span>{{/if}}
                      </p>
                    </header>
                    {{#if description}}<div class="quest-description">{{{description}}}</div>{{/if}}
                    {{#if objectives.length}}
                      <div class="quest-sublist">
                        <h5>Objectives</h5>
                        <ul>
                          {{#each objectives}}
                            {{#unless hidden}}
                              <li class="{{#if done}}is-done{{/if}}">{{{label}}}</li>
                            {{/unless}}
                          {{/each}}
                        </ul>
                      </div>
                    {{/if}}
                  </article>
                {{/each}}
              </div>
            </section>
          {{/each}}
        {{else}}
          <p class="empty-inline">No publishable Forien quests found.</p>
        {{/if}}
      </section>
    {{/if}}

    <section id="fc-gameSessionStory" class="preview-section">
      <h2>Game Session Story</h2>
      {{#if gameSessionStory.chapters.length}}
        <div class="story-toolbar">
          <button type="button" data-story-return>
            <i class="fas fa-bookmark"></i>
            Return to bookmark
          </button>
        </div>
        <div class="story-chapter-list">
          {{#each gameSessionStory.chapters}}
            <article class="story-chapter" data-story-chapter-id="{{id}}">
              <header>
                <p>{{label}}</p>
                <button type="button" data-story-bookmark="{{id}}">
                  <i class="fas fa-bookmark"></i>
                  Bookmark
                </button>
              </header>
              <h3>{{title}}</h3>
              {{#if srcUrl}}<img class="story-chapter-image" src="{{srcUrl}}" alt="">{{/if}}
              {{#if text}}<div class="story-chapter-content">{{{text}}}</div>{{/if}}
            </article>
          {{/each}}
        </div>
      {{else}}
        <p class="empty-inline">{{gameSessionStory.setupMessage}}</p>
      {{/if}}
    </section>

    {{#if exportOptions.journal}}
      <section id="fc-journal" class="preview-section">
        <h2>Journal</h2>
        {{#if journal.entries.length}}
          <div class="folder-list">
            {{#each journal.groups}}
              <details class="folder-group" open>
                <summary>{{path}} <span>{{records.length}}</span></summary>
                <div class="record-list">
                  {{#each records}}
                    <details class="record-row">
                      <summary>{{name}} <span>{{pages.length}} pages</span></summary>
                      {{#if content}}<div class="record-content">{{{content}}}</div>{{/if}}
                      {{#if pages.length}}
                        <ul>
                          {{#each pages}}
                            <li>{{name}} <span class="inline-status">{{type}}</span></li>
                          {{/each}}
                        </ul>
                      {{/if}}
                    </details>
                  {{/each}}
                </div>
              </details>
            {{/each}}
          </div>
        {{else}}
          <p class="empty-inline">No publishable journal entries found.</p>
        {{/if}}
      </section>
    {{/if}}

    {{#if exportOptions.contacts}}
      <section id="fc-contacts" class="preview-section">
        <h2>Contacts</h2>
        {{#if contacts.actors.length}}
          <div class="folder-list">
            {{#each contacts.groups}}
              <details class="folder-group" open>
                <summary>{{path}} <span>{{records.length}}</span></summary>
                <div class="record-grid">
                  {{#each records}}
                    <article class="record-card">
                      {{#if imageUrl}}<img src="{{imageUrl}}" alt="">{{/if}}
                      <div>
                        <h3>{{name}}</h3>
                        {{#if description}}<div class="record-content">{{{description}}}</div>{{/if}}
                        {{#if members.length}}
                          <ul class="module-list">
                            {{#each members}}
                              <li>{{name}} {{#if quantity}}<span>Qty {{quantity}}</span>{{/if}}</li>
                            {{/each}}
                          </ul>
                        {{/if}}
                      </div>
                    </article>
                  {{/each}}
                </div>
              </details>
            {{/each}}
          </div>
        {{else}}
          <p class="empty-inline">No publishable contacts found.</p>
        {{/if}}
      </section>
    {{/if}}

    {{#if exportOptions.items}}
      <section id="fc-items" class="preview-section">
        <h2>Items</h2>
        {{#if items.items.length}}
          <div class="folder-list">
            {{#each items.groups}}
              <details class="folder-group" open>
                <summary>
                  {{#if imageUrl}}<img src="{{imageUrl}}" alt="">{{/if}}
                  {{name}} <span>{{records.length}}</span>
                </summary>
                <div class="record-grid">
                  {{#each records}}
                    <article class="record-card">
                      {{#if imageUrl}}<img src="{{imageUrl}}" alt="">{{/if}}
                      <div>
                        <h3>{{name}}</h3>
                        <p>{{type}}</p>
                      </div>
                    </article>
                  {{/each}}
                </div>
              </details>
            {{/each}}
          </div>
        {{else}}
          <p class="empty-inline">No publishable items found.</p>
        {{/if}}
      </section>
    {{/if}}

    {{#if exportOptions.characterSheets}}
      <section id="fc-characterSheets" class="preview-section">
        <h2>Character Sheets</h2>
        {{#if characterSheets.actors.length}}
          <div class="folder-list">
            {{#each characterSheets.groups}}
              <details class="folder-group" open>
                <summary>{{path}} <span>{{records.length}}</span></summary>
                <div class="record-grid">
                  {{#each records}}
                    <article class="record-card">
                      {{#if imageUrl}}<img src="{{imageUrl}}" alt="">{{/if}}
                      <div>
                        <h3>{{name}}</h3>
                        <p>{{items.length}} embedded items</p>
                      </div>
                    </article>
                  {{/each}}
                </div>
              </details>
            {{/each}}
          </div>
        {{else}}
          <p class="empty-inline">No publishable character sheets found.</p>
        {{/if}}
        {{#if tradeHub.ships.length}}
          <h3 class="preview-subheading">Ships</h3>
          {{#if tradeHub.capitalDisplay}}<p class="empty-inline">TradeHub Capital: {{tradeHub.capitalDisplay}}</p>{{/if}}
          {{#if tradeHub.currentLocation}}<p class="empty-inline">Current Location: {{tradeHub.currentLocation}}</p>{{/if}}
          <div class="record-grid">
            {{#each tradeHub.ships}}
              <article class="record-card ship-card">
                {{#if imageUrl}}<img src="{{imageUrl}}" alt="">{{/if}}
                <div>
                  <h3>{{name}}</h3>
                  <p>HP {{hp.value}}/{{hp.max}} · AC {{ac}} · Cargo {{cargo.current}}/{{cargo.max}}</p>
                  {{#if modules.length}}
                    <h4 class="ship-list-heading">Modules</h4>
                    <ul class="module-list">
                      {{#each modules}}
                        <li>{{name}} {{#if hp.max}}<span>{{hp.value}}/{{hp.max}} HP</span>{{/if}}</li>
                      {{/each}}
                    </ul>
                  {{/if}}
                  {{#if cargoItems.length}}
                    <h4 class="ship-list-heading">Cargo</h4>
                    <ul class="module-list">
                      {{#each cargoItems}}
                        <li>{{name}} <span>Qty {{quantity}} · {{value}} GP</span></li>
                      {{/each}}
                    </ul>
                  {{/if}}
                  {{#if crew.length}}
                    <h4 class="ship-list-heading">Crew</h4>
                    <ul class="module-list">
                      {{#each crew}}
                        <li>{{name}} <span>Qty {{quantity}}</span></li>
                      {{/each}}
                    </ul>
                  {{/if}}
                </div>
              </article>
            {{/each}}
          </div>
        {{/if}}
      </section>
    {{/if}}
    {{#unless exportOptions.characterSheets}}
      {{#if tradeHub.ships.length}}
        <section id="fc-characterSheets" class="preview-section">
          <h2>Ships</h2>
          <div class="record-grid">
            {{#each tradeHub.ships}}
              <article class="record-card ship-card">
                {{#if imageUrl}}<img src="{{imageUrl}}" alt="">{{/if}}
                <div>
                  <h3>{{name}}</h3>
                  <p>HP {{hp.value}}/{{hp.max}} · AC {{ac}} · Cargo {{cargo.current}}/{{cargo.max}}</p>
                </div>
              </article>
            {{/each}}
          </div>
        </section>
      {{/if}}
    {{/unless}}
  </main>
</section>
